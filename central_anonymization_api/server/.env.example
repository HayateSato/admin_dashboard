# ── ECG Anonymization Demo — Server Environment Variables ──────────────────
# Copy this file to server/.env and edit as needed.
# .env is gitignored and must never be committed.

# Hierarchy CSV — bundled inside core/, resolved automatically.
# Override only if you move the CSV elsewhere.
# HIERARCHY_CSV_PATH=/absolute/path/to/ECG_Generalization_hierarchy.csv

# Default k-anonymity level when the client does not specify k_value.
# Must be one of: 2, 3, 5, 10, 20, 30
DEFAULT_K_VALUE=5

# Optional API key — leave empty for open access (local/demo use).
# API_KEY=change-me-to-a-long-random-string

# Port the server listens on.
# Avoid 6000 — Chrome blocks it. 8080 is the safe default.
PORT=8080

# Set to true only during local development.
FLASK_DEBUG=false
