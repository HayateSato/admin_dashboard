# ── Central Anonymization API Server — Environment Variables ──────────────
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# Path to the ECG hierarchy CSV file.
# When running inside the admin_dashboard repo (default dev setup),
# the path below resolves automatically — leave it commented out.
# When deploying standalone, copy smarko_hierarchy_ecg.csv somewhere
# and set an absolute path here.
# HIERARCHY_CSV_PATH=/absolute/path/to/smarko_hierarchy_ecg.csv

# Default k-anonymity level used when the client does not specify k_value.
# Must be one of: 5, 10, 20, 50
DEFAULT_K_VALUE=10

# Optional API key for protecting the server.
# Leave empty to run without authentication (development / internal network only).
# API_KEY=change-me-to-a-long-random-string

# Port the server listens on.
PORT=6000

# Set to true only during local development.
FLASK_DEBUG=false
